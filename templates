<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المنصة الوطنية - حلول إدارية مبتكرة</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --main: #1a6d36; --accent: #fbc02d; --bg: #f4f7f6; }
        body { font-family: 'Tajawal', sans-serif; background: var(--bg); margin: 0; padding: 15px; display: flex; justify-content: center; }
        .app-container { max-width: 450px; width: 100%; background: white; border-radius: 25px; padding: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        .header { text-align: center; margin-bottom: 25px; }
        .header img { width: 60px; margin-bottom: 10px; }
        .header h1 { color: var(--main); font-size: 22px; margin: 0; }
        
        /* شريط البحث المطور */
        .search-area { position: relative; margin-bottom: 30px; }
        .search-area input { width: 100%; padding: 15px 45px 15px 15px; border: 2px solid #eee; border-radius: 15px; box-sizing: border-box; font-size: 16px; outline: none; transition: 0.3s; }
        .search-area input:focus { border-color: var(--main); }
        .search-area button { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); background: var(--main); border: none; color: white; padding: 8px 15px; border-radius: 10px; cursor: pointer; }

        /* قسم "اكتشف حقوقك" - الجاذبية هنا */
        .smart-discovery { margin-top: 20px; }
        .title-box { display: flex; align-items: center; gap: 8px; margin-bottom: 15px; }
        .pulse { width: 10px; height: 10px; background: red; border-radius: 50%; animation: blink 1s infinite; }
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
        
        .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .info-card { background: #fff; border: 1.5px solid #f0f0f0; padding: 15px; border-radius: 18px; text-align: center; cursor: pointer; transition: 0.3s; }
        .info-card:hover { border-color: var(--main); background: #f9fffb; transform: scale(1.03); }
        .card-emoji { font-size: 30px; display: block; margin-bottom: 8px; }
        .card-label { font-size: 13px; font-weight: bold; color: #333; line-height: 1.4; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2c/Flag_of_Morocco.svg" alt="Morocco">
        <h1>المنصة الوطنية للحلول</h1>
        <p style="color: #888; font-size: 13px;">أسرار المساطر الإدارية وحقوقك الضائعة</p>
    </div>

    <form action="/search" method="get" class="search-area">
        <input type="text" name="q" id="search-bar" placeholder="ابحث عن: استرجاع مال، تعويض..." required>
        <button type="submit">بحث</button>
    </form>

    <div class="smart-discovery">
        <div class="title-box">
            <div class="pulse"></div>
            <span style="font-weight: bold; font-size: 15px;">اكتشف أسراراً لا يعرفها الكثيرون:</span>
        </div>
        
        <div class="cards-grid">
            <div class="info-card" onclick="quickSearch('استرجاع تأمين')">
                <span class="card-emoji">💰</span>
                <span class="card-label">استرجع مالك عند بيع السيارة</span>
            </div>
            <div class="info-card" onclick="quickSearch('حفرة الطريق')">
                <span class="card-emoji">🕳️</span>
                <span class="card-label">تعويض مادي عن حفر الطرقات</span>
            </div>
            <div class="info-card" onclick="quickSearch('احتراق الأجهزة')">
                <span class="card-emoji">🔌</span>
                <span class="card-label">تعويض الأجهزة الكهربائية</span>
            </div>
            <div class="info-card" onclick="quickSearch('الرهن البنكي')">
                <span class="card-emoji">⚠️</span>
                <span class="card-label">اكشف هل السيارة مرهونة؟</span>
            </div>
        </div>
    </div>
</div>

<script>
    function quickSearch(val) {
        document.getElementById('search-bar').value = val;
        // سيقوم بتعبئة البحث تلقائياً ليوجه المستخدم
    }
</script>

</body>
</html>
